#!/bin/bash
# kazamo - Voice-to-text tool for Linux
SOCK="${XDG_RUNTIME_DIR:-/tmp}/kazamo.sock"
STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/kazamo-state"
# Resolve symlinks to find the real directory of this script
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
BIN="${KAZAMO_BIN:-$SCRIPT_DIR/src-tauri/target/debug/kazamo}"

send() {
    if command -v ncat &>/dev/null; then
        echo "$1" | ncat -U "$SOCK" 2>/dev/null
    elif command -v nc &>/dev/null; then
        echo "$1" | nc -U "$SOCK" 2>/dev/null
    elif command -v socat &>/dev/null; then
        echo "$1" | socat - UNIX-CONNECT:"$SOCK" 2>/dev/null
    else
        python3 -c "import socket; s=socket.socket(socket.AF_UNIX, socket.SOCK_STREAM); s.connect('$SOCK'); s.sendall(b'$1\n'); print(s.recv(1024).decode().strip())" 2>/dev/null
    fi
}

app_running() { [ -S "$SOCK" ] && send "ping" 2>/dev/null | grep -q "pong"; }

copy_result() {
    command -v wl-copy &>/dev/null && printf "%s" "$1" | wl-copy
}

ydotool_socket() {
    for socket in \
        "${YDOTOOL_SOCKET:-}" \
        "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/.ydotool_socket" \
        "/tmp/.ydotool_socket"
    do
        [ -n "$socket" ] && [ -S "$socket" ] && printf "%s" "$socket" && return 0
    done
    return 1
}

paste_result() {
    [ "${KAZAMO_PASTE:-1}" = "0" ] && return 0
    local text="$1"

    # Give the compositor a brief moment to restore focus after the hotkey command.
    sleep "${KAZAMO_PASTE_DELAY:-0.35}"
    local tool="${KAZAMO_PASTE_TOOL:-auto}"
    local mode="${KAZAMO_PASTE_MODE:-paste}"
    local socket=""

    local preferred_tool="wtype"
    if [ "$XDG_CURRENT_DESKTOP" = "KDE" ]; then
        preferred_tool="ydotool"
    fi
    if [ "$tool" != "auto" ]; then
        preferred_tool="$tool"
    fi

    local tried_ydotool=0
    local tried_wtype=0

    # Try preferred tool first
    if [ "$preferred_tool" = "wtype" ] && command -v wtype &>/dev/null; then
        tried_wtype=1
        if [ "$mode" != "paste" ]; then
            printf "%s" "$text" | wtype - >/dev/null 2>&1 && return 0
        fi
        if [ "$mode" != "type" ]; then
            wtype -M ctrl -k v -m ctrl >/dev/null 2>&1 && return 0
        fi
    elif [ "$preferred_tool" = "ydotool" ] && command -v ydotool &>/dev/null && socket="$(ydotool_socket)"; then
        tried_ydotool=1
        YDOTOOL_SOCKET="$socket" ydotool key 29:1 47:1 47:0 29:0 >/dev/null 2>&1 && return 0
    fi

    # Fallbacks
    if [ $tried_wtype -eq 0 ] && command -v wtype &>/dev/null; then
        if [ "$mode" != "paste" ]; then
            printf "%s" "$text" | wtype - >/dev/null 2>&1 && return 0
        fi
        if [ "$mode" != "type" ]; then
            wtype -M ctrl -k v -m ctrl >/dev/null 2>&1 && return 0
        fi
    fi

    if [ $tried_ydotool -eq 0 ] && command -v ydotool &>/dev/null && socket="$(ydotool_socket)"; then
        YDOTOOL_SOCKET="$socket" ydotool key 29:1 47:1 47:0 29:0 >/dev/null 2>&1 && return 0
    fi

    echo "Copied to clipboard, but automatic paste failed. On KDE run: $SCRIPT_DIR/scripts/setup-ydotoold.sh" >&2
}

ensure_running() {
    if ! app_running; then
        if [ ! -x "$BIN" ]; then
            echo "Error: Kazamo binary not found or not executable: $BIN" >&2
            echo "Run 'npm run tauri dev' or 'cargo build --manifest-path src-tauri/Cargo.toml' first." >&2
            exit 1
        fi
        rm -f "$SOCK" "$STATE_FILE"
        WEBKIT_DISABLE_DMABUF_RENDERER=1 "$BIN" &>/dev/null &
        disown
        for i in $(seq 1 20); do sleep 0.5; app_running && break; done
        if ! app_running; then echo "Error: Failed to start Kazamo: $BIN" >&2; exit 1; fi
        sleep 1
    fi
}

cmd_toggle() {
    ensure_running
    if [ "$(send "status")" = "recording" ]; then
        cmd_stop
    else
        cmd_start
    fi
}

cmd_start() {
    ensure_running
    if [ "$(send "status")" = "recording" ]; then
        echo "Already recording. Use 'kazamo stop' to stop." >&2
        return 1
    fi
    RESULT=$(send "toggle-start")
    if [ "$RESULT" = "started" ]; then
        echo "recording" > "$STATE_FILE"
        echo "Recording started."
    else
        echo "No model downloaded. Open Kazamo and download a model first." >&2
        return 1
    fi
}

cmd_stop() {
    ensure_running
    if [ "$(send "status")" != "recording" ]; then
        echo "Not recording. Use 'kazamo start' to start." >&2
        return 1
    fi
    echo "idle" > "$STATE_FILE"
    send "set-idle" >/dev/null
    echo "Transcribing..." >&2
    RESULT=$(send "toggle-stop")
    if [ -n "$RESULT" ] && [ "$RESULT" != "error" ] && [ "$RESULT" != "?" ]; then
        echo "$RESULT"
        if copy_result "$RESULT"; then
            paste_result "$RESULT"
        else
            echo "Install wl-clipboard for clipboard support." >&2
        fi
    else
        echo "No speech detected." >&2
        return 1
    fi
}

cmd_status() {
    if app_running; then
        send "status"
    else
        echo "stopped"
    fi
}

cmd_show() {
    ensure_running
    send "show" >/dev/null
}

show_help() {
    cat << 'HELP'
kazamo - Voice-to-text for Linux

Usage:
  kazamo <command>

Commands:
  toggle       Toggle recording (start or stop + transcribe)
  start        Start recording
  stop         Stop recording and transcribe
  status       Show current status (idle / recording / stopped)
  show         Bring window to front
  help         Show this help

Examples:
  kazamo toggle              # One-key recording workflow
  kazamo start && sleep 3 && kazamo stop
  kazamo stop                # Stop and get transcription

Global hotkey (labwc ~/.config/labwc/rc.xml):
  <keybind key="A-r">
    <action name="Execute">
      <command>kazamo toggle</command>
    </action>
  </keybind>
HELP
}

case "${1:-help}" in
    toggle)  cmd_toggle ;;
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    status)  cmd_status ;;
    show)    cmd_show ;;
    help|-h|--help)  show_help ;;
    *)       echo "Unknown command: $1" >&2; echo "Run 'kazamo help' for usage." >&2; exit 1 ;;
esac
