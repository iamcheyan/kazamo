{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Kazamo",
  "version": "0.1.0",
  "identifier": "com.kazamo.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "./scripts/ensure-sherpa-python.sh && npm run dev",
    "beforeBuildCommand": "./scripts/ensure-sherpa-python.sh && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kazamo",
        "width": 525,
        "height": 582,
        "minWidth": 525,
        "minHeight": 582,
        "maximizable": false,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["resources/bin/*", "resources/python/**/*"]
  }
}
